# Agent Configuration - Environment Variables
# Copy this file to .env and modify as needed.

# 本地模型服务配置
# LOCAL_MODEL_URI=ws://192.168.31.43:8000/ws/navigate

# OpenAI兼容客户端配置
# OPENAI_API_KEY=0
# OPENAI_BASE_URL=http://192.168.31.43:9000/v1
# OPENAI_MODEL=Qwen3-VL-30B-A3B-Instruct

# USB串口配置
# USB_SERIAL_PORT=/dev/ttyACM0
# USB_SERIAL_BAUDRATE=115200

# 数据库和文件路径
# DB_PATH=history.db
# ASM_JSON_PATH=asm_data.json
# VIDEO_BASE_DIR=videos

# WebSocket配置
# WEBSOCKET_HOST=0.0.0.0
# WEBSOCKET_PORT=8766
